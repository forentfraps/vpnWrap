{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "dns": {
    "servers": [
      { "tag": "doh", "address": "https://1.1.1.1/dns-query" },
      { "tag": "local", "address": "local", "detour": "direct" }
    ],
    "rules": [
      { "domain_suffix": [".cn"], "server": "local" }
    ],
    "strategy": "ipv4_only"
  },

  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "127.0.0.1",
      "listen_port": 1080,
      "users": [
        { "uuid": "__VLESS_UUID__", "name": "default" }
      ],
      "sniff": true,
      "sniff_override_destination": true
    }
  ],

  "outbounds": [
    {
      "type": "direct",
      "tag": "direct",
      "domain_strategy": "ipv4_only"
    },
    { "type": "block",  "tag": "block"  },
    { "type": "dns",    "tag": "dns-out" }
  ],

  "route": {
    "rules": [
      { "protocol": "dns", "outbound": "dns-out" },
      { "ip_is_private": true, "outbound": "block" },
      { "ip_version": 6, "outbound": "block" }
    ],
    "final": "direct",
    "auto_detect_interface": true
  }
}
